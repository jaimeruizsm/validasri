{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"],
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": "..",
    "paths": {
      "@validasri/shared": ["./packages/shared/src/index.ts"],
      "@validasri/validation": ["./packages/validation/src/index.ts"],
      "@validasri/sri-client": ["./packages/sri-client/src/index.ts"],
      "@validasri/database": ["./packages/database/src/index.ts"],
      "@validasri/export": ["./packages/export/src/index.ts"]
    }
  },
  "include": ["**/*.ts", "../playwright.config.ts"]
}
