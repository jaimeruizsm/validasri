# ------------------------------------------------------------------
# ValidaSRI - variables de entorno
# Copia este archivo a .env y completa los valores. NUNCA subas .env al repo.
# ------------------------------------------------------------------

# Capa de datos: "local" (SQLite, no requiere Supabase) o "supabase"
DATA_PROVIDER=local

# Ruta del archivo SQLite cuando DATA_PROVIDER=local
LOCAL_DB_PATH=.data/validasri.db

# Secreto para firmar la cookie de sesion en modo local (min. 32 caracteres).
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LOCAL_SESSION_SECRET=

# ------------------------- Supabase (DATA_PROVIDER=supabase) ----------
# Panel de Supabase -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo servidor / worker. Jamas debe llegar al navegador (llave "service_role secret").
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------ SRI ----------------------------------
# Proveedor: "mock" (demostracion, sin red) o "soap" (Web Service oficial)
SRI_PROVIDER=mock

# Entorno del SRI: "test" o "production"
SRI_ENVIRONMENT=test

SRI_TEST_WSDL_URL=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/ConsultaComprobante?wsdl
SRI_PRODUCTION_WSDL_URL=https://cel.sri.gob.ec/comprobantes-electronicos-ws/ConsultaComprobante?wsdl

# ------------------------- Limites de carga ---------------------------
MAX_TXT_SIZE_MB=5
# Maximo de claves validas por archivo TXT
MAX_KEYS_PER_BATCH=500

# ------------------------------ Worker --------------------------------
WORKER_CONCURRENCY=3
SRI_REQUEST_TIMEOUT_MS=20000
SRI_MAX_RETRIES=3
SRI_REQUEST_DELAY_MS=500
WORKER_POLL_INTERVAL_MS=3000
# Tamano del lote que reclama el worker en cada ciclo
WORKER_CLAIM_SIZE=25
# Tiempo tras el cual un item bloqueado por un worker caido se libera
WORKER_LOCK_TIMEOUT_MS=120000

# ------------------------------ Web -----------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
