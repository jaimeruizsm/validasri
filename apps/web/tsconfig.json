{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2023"
    ],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@validasri/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@validasri/validation": [
        "../../packages/validation/src/index.ts"
      ],
      "@validasri/sri-client": [
        "../../packages/sri-client/src/index.ts"
      ],
      "@validasri/database": [
        "../../packages/database/src/index.ts"
      ],
      "@validasri/export": [
        "../../packages/export/src/index.ts"
      ]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
